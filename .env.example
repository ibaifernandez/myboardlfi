# ── Puerto del servidor ───────────────────────────────────────────────────────
PORT=3003

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_publica
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_PRIVADA  # nunca exponer al cliente
JWT_SECRET=your-random-secret-min-32-chars

# ── SMTP (Resend en producción) ────────────────────────────────────────────────
SMTP_HOST=your-smtp-host
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="MyBoardLFi <myboard@tudominio.com>"

# ── Digest ────────────────────────────────────────────────────────────────────
DIGEST_TO=email@tudominio.com
DIGEST_HOUR=6
